#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
emacs_bin=${EMACS:-emacs}
emacsclient_bin=${EMACSCLIENT:-emacsclient}
tmux_bin=${TMUX_BIN:-tmux}
qa_id=${TMUX_EMACS_CSI_U_QA_ID:-$$}
socket=${TMPDIR:-/tmp}/tmux-emacs-csi-u-qa-${qa_id}.sock
server=tmux-emacs-csi-u-qa-${qa_id}
session=tmux-emacs-csi-u-qa
init_file=$repo_root/.tmp/qa-init-${qa_id}.el
result_file=$repo_root/.tmp/qa-result-${qa_id}.el

mkdir -p "$repo_root/.tmp"

cat > "$init_file" <<EOF
(add-to-list 'load-path "$repo_root")
(require 'cl-lib)
(require 'tmux-emacs-csi-u)
(setq tmux-emacs-csi-u-auto-enable t)
EOF

"$emacs_bin" --daemon="$server" --quick --load "$init_file" >/dev/null 2>&1
sleep 1

cleanup() {
  "$emacsclient_bin" -s "$server" -e '(kill-emacs)' >/dev/null 2>&1 || true
  "$tmux_bin" -S "$socket" kill-server >/dev/null 2>&1 || true
}
trap cleanup EXIT

"$tmux_bin" -S "$socket" -f /dev/null new-session -d -s "$session" \
  "TERM=tmux-256color $emacsclient_bin -s $server -t -a '' --eval \"(let ((result-file \\\"$result_file\\\")) (with-temp-file result-file (prin1 (list :supported (tmux-emacs-csi-u-supported-p) :report (tmux-emacs-csi-u-enable) :keys (cl-loop repeat 13 collect (key-description (read-key-sequence-vector \\\"\\\")))) (current-buffer))) (save-buffers-kill-terminal))\""

sleep 2

for seq in \
  $'\e[32;2u' \
  $'\e[127;2u' \
  $'\e[59;2u' \
  $'\e[47;2u' \
  $'\e[46;2u' \
  $'\e[44;2u' \
  $'\e[39;2u' \
  $'\e[91;2u' \
  $'\e[93;2u' \
  $'\e[92;2u' \
  $'\e[61;2u' \
  $'\e[45;2u' \
  $'\e[96;2u'
do
  "$tmux_bin" -S "$socket" send-keys -t "$session":0.0 -l -- "$seq"
  sleep 0.2
done

sleep 2

printf 'qa smoke command path:\n'
printf '  daemon: %s --daemon=%q --quick --load %q\n' "$emacs_bin" "$server" "$init_file"
printf '  tty client: TERM=tmux-256color %s -s %q -t -a %q\n' "$emacsclient_bin" "$server" ''
printf '\nqa smoke result:\n'
cat "$result_file"
printf '\n'

python3 - <<PY
from pathlib import Path
text = Path(r"$result_file").read_text()
needles = [
    ':supported t',
    ':support-signal tty-type',
    '"SPC"',
    '"DEL"',
    '":"',
    '"?"',
    '">"',
    '"<"',
    '"\\\""',
    '"{"',
    '"}"',
    '"|"',
    '"+"',
    '"_"',
    '"~"',
]
missing = [needle for needle in needles if needle not in text]
if missing:
    raise SystemExit(f"qa smoke missing expectations: {missing}")
PY

printf 'qa smoke ok\n'
