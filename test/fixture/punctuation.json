{
  "format_version": 1,
  "capture": {
    "command": "cat -v",
    "tmux_version": "tmux 3.6a",
    "emacs_version": "GNU Emacs 30.2",
    "terminal_app": "Ghostty 1.3.1",
    "input_source": "ABC"
  },
  "entries": [
    { "char": ":", "sequence": "\\\\e[59;2u", "event": ":" },
    { "char": "?", "sequence": "\\\\e[47;2u", "event": "?" },
    { "char": ">", "sequence": "\\\\e[46;2u", "event": ">" },
    { "char": "<", "sequence": "\\\\e[44;2u", "event": "<" },
    { "char": "\"", "sequence": "\\\\e[39;2u", "event": "\"" },
    { "char": "{", "sequence": "\\\\e[91;2u", "event": "{" },
    { "char": "}", "sequence": "\\\\e[93;2u", "event": "}" },
    { "char": "|", "sequence": "\\\\e[92;2u", "event": "|" },
    { "char": "+", "sequence": "\\\\e[61;2u", "event": "+" },
    { "char": "_", "sequence": "\\\\e[45;2u", "event": "_" },
    { "char": "~", "sequence": "\\\\e[96;2u", "event": "~" }
  ]
}
